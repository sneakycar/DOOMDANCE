; Engine configuration file.
; RETURN BUT DIFFERENT — iOS-only. Open in Godot → Export → iOS.

config_version=5

[application]

config/name="RETURN BUT DIFFERENT"
config/description="Living-world simulation — iOS."
run/main_scene="res://return_but_different/main.tscn"
config/features=PackedStringArray("4.4", "Mobile")
config/icon="res://icon.svg"

[autoload]

DoomMusic="*res://scripts/game/doom_music.gd"

[display]

window/size/viewport_width=390
window/size/viewport_height=844
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[input_devices]

pointing/emulate_touch_from_mouse=false

[rendering]

renderer/rendering_method="mobile"
textures/canvas_textures/default_texture_filter=0
environment/defaults/default_clear_color=Color(0.02, 0.02, 0.03, 1)
2d/snap/snap_2d_transforms_to_pixel=true
